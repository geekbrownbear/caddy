# =============================================================================
#  Bearium Caddy Proxy — Environment Variables
#  This is the shared reverse proxy stack.  Copy to .env before first run.
# =============================================================================

# Email Let's Encrypt will use for expiry notifications.
ACME_EMAIL=admin@bearium.net

# Cloudflare API token, scoped to Zone:DNS:Edit on the bearium.net zone only.
# Used for the DNS-01 ACME challenge so internal-only hostnames (e.g.
# *.local.bearium.net, never publicly resolvable) can still get real,
# publicly-trusted certs - Let's Encrypt only needs to see a public TXT
# record, not reach the host over HTTP.
CF_API_TOKEN=
